# Server-side only (NEVER use NEXT_PUBLIC_ prefix for secrets!)
BASE_SEPOLIA_RPC_URL=https://base-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_API_KEY
DEPLOYER_PRIVATE_KEY=0xYOUR_DEPLOYER_PRIVATE_KEY_HERE

# Supabase Configuration (v2 API Key Format)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_y...e
SUPABASE_SERVICE_ROLE_KEY=sb_secret_y...e  # Server-side only, NEVER expose to client!

# Filebase (IPFS) Configuration
# REQUIRED for bottle creation to work in production
# Get your credentials from: https://filebase.com/
# 1. Create an account (Free tier: 5GB storage, unlimited egress)
# 2. Create an IPFS bucket in the Filebase console
# 3. Generate access keys in the Access Keys section
FILEBASE_ACCESS_KEY_ID=your_access_key_id_here
FILEBASE_SECRET_ACCESS_KEY=your_secret_access_key_here
FILEBASE_BUCKET_NAME=your-bucket-name  # The IPFS bucket you created in Filebase

# Client-side (safe to expose)
NEXT_PUBLIC_CONTRACT_ADDRESS=0xe9392f61C18c897cC5e49e3D8b23F9a5704d3342
# Filebase gateway format: https://{bucket-name}.ipfs.filebase.io
NEXT_PUBLIC_IPFS_GATEWAY=https://your-bucket-name.ipfs.filebase.io
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your-walletconnect-project-id  # Get from: https://cloud.walletconnect.com
NEXT_PUBLIC_APP_URL=http://localhost:3000  # For production, use your prod URL (e.g., https://forever.loscolmebrothers.com)